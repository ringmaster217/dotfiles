#!/bin/bash

# Launch or focus on a given web app identified by the window-pattern.
# Use for key bindings to ensure there is only one instance of the application open.

if (($# == 0)); then
  echo "Usage: cachy-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="cachy-launch-webapp $@"

exec cachy-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
