#!/bin/bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like cachy-launch-wifi to ensure there is only one wifi configuration screen open.

APP_ID="org.cachy.$(basename "$1")"
LAUNCH_COMMAND="cachy-launch-tui $@"

exec cachy-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
