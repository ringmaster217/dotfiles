#!/bin/bash

# Lock the screen using hyprlock with the current desktop wallpaper blurred as
# the background. The current wallpaper is determined by reading the same state
# file written by cachy-wallpaper.

BACKGROUNDS_DIR="${HOME}/.config/backgrounds"
STATE_FILE="${HOME}/.local/state/cachy-wallpaper"

# Build the same sorted image list that cachy-wallpaper uses.
mapfile -t images < <(find "$BACKGROUNDS_DIR" -maxdepth 1 -type f \
    \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' \
       -o -iname '*.webp' -o -iname '*.gif' \) | sort)

count=${#images[@]}

if (( count == 0 )); then
    # No wallpaper found — tell hyprlock to render a plain background.
    export HYPRLOCK_WALLPAPER=clear
else
    # Read current index; default to 0 if missing.
    if [[ -f "$STATE_FILE" ]]; then
        index=$(< "$STATE_FILE")
    else
        index=0
    fi

    # Clamp to valid range in case the backgrounds directory changed.
    if (( index < 0 || index >= count )); then
        index=0
    fi

    export HYPRLOCK_WALLPAPER="${images[$index]}"
fi

# hyprlock does not daemonize itself, so background it so that swayidle's
# before-sleep hook can return and allow the system to suspend.
hyprlock &

# Give hyprlock a moment to render its lock surface, then turn the display
# back on so the lock screen (not the previous desktop) is what the user sees.
sleep 0.5
swaymsg "output * dpms on"
