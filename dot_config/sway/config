# Read `man 5 sway` for a complete reference.

### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
set $term footclient
# Your preferred application launcher
set $menu rofi -show drun

### Includes
include /etc/sway/config.d/*
include './outputs'
include './conf.d/output.conf'
include './conf.d/idle.conf'
include './conf.d/input.conf'
include './conf.d/autostart.conf'
include './conf.d/keybindings.conf'
include './conf.d/look_and_feel.conf'
include './conf.d/rules.conf'
include './conf.d/bar.conf'
